# ========================================
# AI Prompt Studio - 环境变量模板
# 复制此文件为 .env 并填入真实值
# Vercel 部署时在 Project Settings → Environment Variables 中配置
# ========================================

# ---- AI Provider API Keys（Phase 3 启用）----
# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic Claude API Key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Google Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# ---- 应用配置 ----
# 应用名称（显示在标题栏）
NEXT_PUBLIC_APP_NAME=AI Prompt Studio

# 默认语言（zh | en）
NEXT_PUBLIC_DEFAULT_LANG=zh

# ---- 分析与监控（可选）----
# Vercel Analytics（Vercel 自动注入，无需手动配置）
# VERCEL_ANALYTICS_ID=

# Sentry 错误追踪 DSN（可选）
SENTRY_DSN=
